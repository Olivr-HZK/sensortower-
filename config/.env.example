# SensorTower API 配置示例
# 注意：Google Apps Script 不支持直接读取 .env 文件
# 请使用菜单中的「🔑 配置 API Key」功能来配置

# SensorTower API Token
# 获取方式：登录 SensorTower → API 设置 → 生成 Token
SENSORTOWER_API_TOKEN=your_api_token_here

# Google Doc ID（可选）
# 如果不配置，系统会自动创建新文档
# 从文档 URL 中获取：https://docs.google.com/document/d/DOC_ID/edit
GOOGLE_DOC_ID=

# 示例：
# SENSORTOWER_API_TOKEN=abc123xyz789
# GOOGLE_DOC_ID=1a2b3c4d5e6f7g8h9i0j
